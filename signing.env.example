# 1Password secret references for local signing.
# Copy this file to signing.env and replace with your actual 1Password vault/item paths.
# signing.env is gitignored — it is safe to store your references there.
#
# See: https://developer.1password.com/docs/cli/secret-references

KEYSTORE_REF=op://Vault/Item/keystore-file
STORE_PASSWORD=op://Vault/Item/store-password
KEY_ALIAS=op://Vault/Item/key-alias
KEY_PASSWORD=op://Vault/Item/key-password
